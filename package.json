{
  "name": "acp-pipeline-reference",
  "version": "0.1.0",
  "private": true,
  "description": "Reference pipeline for loading enterprise data into the Agent Context Platform.",
  "license": "Apache-2.0",
  "type": "module",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "build": "pnpm -r build",
    "clean": "pnpm -r clean",
    "test": "pnpm -r --if-present test",
    "test:integration": "pnpm -r --if-present test:integration",
    "typecheck": "pnpm -r --if-present typecheck",
    "seed": "tsx source-data/seed.ts",
    "pipeline:run": "pnpm -r build && tsx bin/pipeline-run.ts"
  },
  "devDependencies": {
    "@acp/connector-postgres": "workspace:*",
    "@acp/pipeline-core": "workspace:*",
    "@faker-js/faker": "^8.4.1",
    "@types/node": "^20.14.0",
    "@types/pg": "^8.11.6",
    "esbuild": "^0.21.5",
    "pg": "^8.11.5",
    "tsx": "^4.16.2",
    "typescript": "^5.4.5"
  }
}
